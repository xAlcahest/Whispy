{
  "name": "whispy-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local dictation UI shell built with Electron + React",
  "author": {
    "name": "Whispy Team",
    "email": "packaging@whispy.local"
  },
  "main": "out/main/index.js",
  "build": {
    "appId": "com.whispy.ui",
    "executableName": "whispy",
    "icon": "assets4app/Web/android-chrome-512x512.png",
    "linux": {
      "maintainer": "Whispy Team <packaging@whispy.local>",
      "icon": "assets4app/Web/android-chrome-512x512.png",
      "category": "Utility"
    },
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "scripts": {
    "predev": "npm run prepare:whisper-runtime",
    "dev": "electron-vite dev",
    "prebuild": "npm run prepare:whisper-runtime",
    "build": "electron-vite build",
    "prepare:whisper-runtime": "node scripts/prepare-whisper-runtime.mjs --current --variants=cpu,cuda",
    "prepare:whisper": "node scripts/prepare-whisper-stack.mjs --current --variants=cpu,cuda",
    "build:linux": "node scripts/prepare-whisper-runtime.mjs --platform=linux --arch=x64 --variants=cpu,cuda && electron-vite build",
    "build:win": "node scripts/prepare-whisper-runtime.mjs --platform=win32 --arch=x64 --variants=cpu,cuda && electron-vite build",
    "build:mac": "node scripts/prepare-whisper-runtime.mjs --platform=darwin --arch=arm64 --variants=cpu,cuda && electron-vite build",
    "dist:linux": "npm run build && npx electron-builder --linux AppImage rpm deb tar.gz",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "doctor": "node scripts/doctor.mjs",
    "lint": "eslint .",
    "test": "tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "@lobehub/icons-static-svg": "^1.84.0",
    "@uiw/react-markdown-preview": "^5.1.5",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.1",
    "get-windows": "^9.3.0",
    "lucide-react": "^0.475.0",
    "marked": "^17.0.3",
    "node-record-lpcm16": "^1.0.1",
    "openai": "^6.33.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^41.1.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.3.1"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  }
}
