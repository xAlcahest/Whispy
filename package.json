{
  "name": "whispy-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local dictation UI shell built with Electron + React",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "prepare:whisper-runtime": "node scripts/prepare-whisper-runtime.mjs --current",
    "build:linux": "node scripts/prepare-whisper-runtime.mjs --platform=linux --arch=x64 && electron-vite build",
    "build:win": "node scripts/prepare-whisper-runtime.mjs --platform=win32 --arch=x64 && electron-vite build",
    "build:mac": "node scripts/prepare-whisper-runtime.mjs --platform=darwin --arch=arm64 && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "doctor": "node scripts/doctor.mjs",
    "lint": "eslint .",
    "test": "tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "@lobehub/icons-static-svg": "^1.79.0",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "get-windows": "^9.2.3",
    "lucide-react": "^0.475.0",
    "node-record-lpcm16": "^1.0.1",
    "openai": "^6.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tailwindcss/vite": "^4.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "electron-vite": "^2.3.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.3.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.55.0",
    "vite": "^5.4.11"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  }
}
